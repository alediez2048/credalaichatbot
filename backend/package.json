{
  "name": "onboarding-assistant",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/application.js --bundle --outdir=app/assets/builds --loader:.jsx=jsx",
    "build:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "build:css:watch": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --watch"
  },
  "dependencies": {
    "@hotwired/turbo": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "esbuild": "^0.24.0",
    "tailwindcss": "^3.4.0"
  }
}
