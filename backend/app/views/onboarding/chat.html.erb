<div class="mx-auto max-w-3xl px-4 py-6 sm:px-6" style="height: calc(100vh - 72px);">
  <div class="h-full flex flex-col rounded-2xl border border-[#E0E0E0] bg-white shadow-credal">
    <%# Progress bar %>
    <div class="px-4 pt-4 pb-2">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-light text-[#777777]" data-step-label>
          Step: <%= @onboarding_session.current_step&.humanize || "Welcome" %>
        </span>
        <div class="flex items-center gap-2">
          <span class="text-xs font-light text-[#777777]" data-progress-label>
            <%= @onboarding_session.progress_percent || 0 %>%
          </span>
          <% if @resuming && !@completed %>
            <%= button_to "Start over", onboarding_reset_path, method: :post, class: "text-xs font-light text-[#777777] hover:text-credal-purple underline", data: { turbo_confirm: "This will clear all your progress. Are you sure?" } %>
          <% end %>
        </div>
      </div>
      <div class="h-1 w-full rounded-full bg-[rgba(0,0,0,0.03)]">
        <div class="h-1 rounded-full bg-[#6D46DE] transition-all duration-500" data-progress-bar style="width: <%= @onboarding_session.progress_percent || 0 %>%"></div>
      </div>
    </div>

    <%# Chat container %>
    <div id="chat-root"
         class="flex-1 min-h-0"
         data-session-id="<%= @onboarding_session.id %>"
         data-initial-messages="<%= j @onboarding_session.messages.order(:created_at).map { |m| { id: m.id, role: m.role, content: m.content.to_s } }.to_json %>"
         data-current-step="<%= @onboarding_session.current_step %>"
         data-progress="<%= @onboarding_session.progress_percent || 0 %>"
         data-resuming="<%= @resuming %>"
         data-completed="<%= @completed %>">
    </div>
  </div>
</div>
