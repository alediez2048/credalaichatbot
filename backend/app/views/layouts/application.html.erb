<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Onboarding Assistant</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <% if notice.present? %>
      <p class="bg-green-100 text-green-800 px-4 py-2 text-sm"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="bg-red-100 text-red-800 px-4 py-2 text-sm"><%= alert %></p>
    <% end %>
    <header class="border-b border-gray-200 bg-white">
      <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3 sm:px-6">
        <%= link_to "Onboarding Assistant", root_path, class: "text-lg font-semibold text-gray-900 hover:text-gray-700" %>
        <div class="flex items-center gap-3">
          <% if user_signed_in? %>
            <span class="text-sm text-gray-600"><%= current_user.email %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
            <span class="text-gray-400">|</span>
            <%= link_to "Sign up", new_user_registration_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
          <% end %>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-4xl px-4 py-6 sm:px-6">
      <%= yield %>
    </main>
  </body>
</html>
