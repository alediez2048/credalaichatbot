<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Credal · Onboarding Assistant</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="action-cable-url" content="/cable">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="min-h-screen bg-white font-sans text-credal-dark-gray antialiased font-light">
    <% if notice.present? %>
      <p class="bg-green-50 text-credal-green px-4 py-2 text-sm"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="bg-red-50 text-credal-red px-4 py-2 text-sm"><%= alert %></p>
    <% end %>
    <header class="sticky top-0 z-50 bg-white">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <%= image_tag "credal-logo.png", alt: "Credal", class: "h-8 w-auto" %>
        <% end %>
        <div class="flex items-center gap-3">
          <% if user_signed_in? %>
            <span class="text-sm text-credal-medium-gray font-light"><%= current_user.email %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-pill bg-credal-black px-3 py-1.5 text-sm font-light text-white hover:opacity-90" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "text-sm font-light text-credal-medium-gray hover:text-credal-black" %>
            <%= link_to "Get started", new_user_registration_path, class: "rounded-pill bg-credal-black px-3 py-1.5 text-sm font-light text-white hover:opacity-90" %>
          <% end %>
        </div>
      </nav>
    </header>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
