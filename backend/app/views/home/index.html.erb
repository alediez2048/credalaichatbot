<section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
  <div class="max-w-2xl">
    <h1 class="text-[55px] font-normal leading-[1.15] tracking-[0.55px] text-black">
      AI-Powered Onboarding
    </h1>
    <p class="mt-4 text-lg font-light leading-relaxed text-credal-dark-gray">
      Complete your employee onboarding in minutes — not hours.
      Our AI assistant guides you through every step: data collection,
      document verification, and appointment scheduling.
    </p>
    <%= link_to onboarding_path, class: "mt-8 inline-block rounded-pill bg-credal-purple px-6 py-3 text-lg font-light text-white hover:opacity-90" do %>
      Start Onboarding &rarr;
    <% end %>
  </div>
</section>

<section class="bg-credal-black py-16">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <h2 class="text-2xl font-medium text-white">What you get</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      <div class="flex items-start gap-3">
        <span class="mt-1 text-credal-green">&#10003;</span>
        <p class="text-lg font-light text-white">AI-guided conversational flow</p>
      </div>
      <div class="flex items-start gap-3">
        <span class="mt-1 text-credal-green">&#10003;</span>
        <p class="text-lg font-light text-white">Instant document scanning & extraction</p>
      </div>
      <div class="flex items-start gap-3">
        <span class="mt-1 text-credal-green">&#10003;</span>
        <p class="text-lg font-light text-white">Smart appointment scheduling</p>
      </div>
      <div class="flex items-start gap-3">
        <span class="mt-1 text-credal-green">&#10003;</span>
        <p class="text-lg font-light text-white">Progress tracking & emotional support</p>
      </div>
    </div>
  </div>
</section>

<footer class="bg-credal-black border-t border-white/10 py-8">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex items-center justify-between">
      <%= image_tag "credal-logo.png", alt: "Credal", class: "h-6 w-auto brightness-0 invert" %>
      <p class="text-sm font-light text-white">Powered by GPT-4o</p>
    </div>
  </div>
</footer>
