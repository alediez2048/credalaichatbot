<div class="mx-auto mt-16 max-w-md rounded-2xl border border-[#E0E0E0] bg-white p-8 shadow-credal">
  <h2 class="text-2xl font-medium text-credal-black">Sign in</h2>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-light text-credal-medium-gray" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border border-[#E0E0E0] px-3 py-2 text-sm font-light focus:border-credal-purple focus:outline-none focus:ring-1 focus:ring-credal-purple" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-light text-credal-medium-gray" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 block w-full rounded-lg border border-[#E0E0E0] px-3 py-2 text-sm font-light focus:border-credal-purple focus:outline-none focus:ring-1 focus:ring-credal-purple" %>
    </div>
    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-[#E0E0E0] text-credal-purple focus:ring-credal-purple" %>
        <%= f.label :remember_me, class: "ml-2 block text-sm font-light text-credal-medium-gray" %>
      </div>
    <% end %>
    <div>
      <%= f.submit "Sign in", class: "w-full rounded-pill bg-credal-purple px-4 py-2 text-sm font-light text-white hover:opacity-90 cursor-pointer" %>
    </div>
  <% end %>
  <%= render "devise/shared/links" %>
</div>
