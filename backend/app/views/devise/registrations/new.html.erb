<div class="mx-auto mt-16 max-w-md rounded-2xl border border-[#E0E0E0] bg-white p-8 shadow-credal">
  <h2 class="text-2xl font-medium text-credal-black">Sign up</h2>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <div>
      <%= f.label :email, class: "block text-sm font-light text-credal-medium-gray" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border border-[#E0E0E0] px-3 py-2 text-sm font-light focus:border-credal-purple focus:outline-none focus:ring-1 focus:ring-credal-purple" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-light text-credal-medium-gray" %>
      <% if @minimum_password_length %>
        <span class="text-sm font-light text-credal-light-gray">(<%= @minimum_password_length %> characters minimum)</span>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full rounded-lg border border-[#E0E0E0] px-3 py-2 text-sm font-light focus:border-credal-purple focus:outline-none focus:ring-1 focus:ring-credal-purple" %>
    </div>
    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-light text-credal-medium-gray" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full rounded-lg border border-[#E0E0E0] px-3 py-2 text-sm font-light focus:border-credal-purple focus:outline-none focus:ring-1 focus:ring-credal-purple" %>
    </div>
    <div>
      <%= f.submit "Sign up", class: "w-full rounded-pill bg-credal-purple px-4 py-2 text-sm font-light text-white hover:opacity-90 cursor-pointer" %>
    </div>
  <% end %>
  <%= render "devise/shared/links" %>
</div>
