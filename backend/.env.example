# PostgreSQL (required for db:create / db:migrate)
# If you get "no password supplied", set DATABASE_PASSWORD to your postgres user's password
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost

REDIS_URL=redis://localhost:6379/0
SECRET_KEY_BASE=

# OpenAI (P0-003+)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LangSmith observability (P0-005). Omit to disable tracing (no-op).
LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=default
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# CI eval threshold (P5-005). Minimum pass rate % to pass CI.
# EVAL_PASS_THRESHOLD=85
